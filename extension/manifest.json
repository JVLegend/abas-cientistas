{
  "manifest_version": 3,
  "name": "Abas Cientistas",
  "version": "1.0.0",
  "description": "Nova aba para cientistas de dados organizarem abas abertas por código, GitHub, apps, mensageria, vídeos, papers e projetos.",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Abas Cientistas",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
